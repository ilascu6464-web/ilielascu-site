```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Logs
*.log

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Build/dist folders
dist/
build/
target/

# Coverage reports
coverage/
htmlcov/
.coverage

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
node_modules/

# OS generated files
.DS_Store
Thumbs.db
```